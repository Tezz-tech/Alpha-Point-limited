# ─────────────────────────────────────────────────────────────────────────────
# Google Calendar — Automated Booking + Google Meet
#
# Client ID (already set — from Google Cloud Console):
# 244824019615-bsk4caajiqih6acp78kg5ojeq7i9ssh6.apps.googleusercontent.com
#
# Calendar owner email: emmakleen@gmail.com
#
# ── YOU STILL NEED (one-time setup, ~5 minutes): ──────────────────────────
#
# STEP 1 — Get your Client Secret
#   1. Go to https://console.cloud.google.com
#   2. Select your project → APIs & Services → Credentials
#   3. Find your OAuth 2.0 Client ID → click the edit (pencil) icon
#   4. Copy the "Client secret" value
#
# STEP 2 — Get your Refresh Token (one-time OAuth flow)
#   1. Go to https://developers.google.com/oauthplayground
#   2. Click the gear icon (⚙) top-right → check "Use your own OAuth credentials"
#   3. Paste your Client ID and Client Secret → Close
#   4. In the left panel, find "Google Calendar API v3"
#      Select scope: https://www.googleapis.com/auth/calendar
#   5. Click "Authorize APIs" → sign in as emmakleen@gmail.com → Allow
#   6. Click "Exchange authorization code for tokens"
#   7. Copy the "Refresh token" value — save it, you only see it once!
#
# STEP 3 — Add all values below, then add them to Vercel dashboard too
# ─────────────────────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=244824019615-bsk4caajiqih6acp78kg5ojeq7i9ssh6.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_CALENDAR_ID=emmakleen@gmail.com
